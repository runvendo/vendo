{
  "format": "vendo/tools@1",
  "tools": [
    {
      "name": "send_trip_report",
      "description": "Email a weather/trip report to a recipient. Sends real mail on the user's behalf, so it needs their approval.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "recipient": {
            "type": "string",
            "description": "Email address to send the report to"
          },
          "report": {
            "type": "string",
            "description": "The report text to send"
          }
        },
        "required": ["recipient", "report"],
        "additionalProperties": false
      },
      "risk": "write",
      "binding": {
        "kind": "server-action",
        "module": "src/lib/vendo-actions.ts",
        "exportName": "sendTripReport",
        "params": ["recipient", "report"]
      }
    }
  ]
}
