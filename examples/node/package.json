{
  "name": "@flowlet/example-node",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-flowlet-sandbox.mjs",
    "dev": "concurrently -k -n api,web \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx server.mjs",
    "dev:web": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@flowlet/next": "workspace:*",
    "@flowlet/server": "workspace:*",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
