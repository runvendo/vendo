{
  "name": "@vendoai/server",
  "version": "0.2.0",
  "description": "Provider-agnostic server engine for Vendo embedded agents.",
  "keywords": ["ai", "agent", "generative-ui", "server", "llm"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo-server"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.ts",
      "import": "./dist/capabilities.js",
      "default": "./dist/capabilities.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "import": "./dist/model.js",
      "default": "./dist/model.js"
    },
    "./manifest-tools": {
      "types": "./dist/manifest-tools.d.ts",
      "import": "./dist/manifest-tools.js",
      "default": "./dist/manifest-tools.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js",
      "default": "./dist/catalog.js"
    }
  },
  "typesVersions": {
    "*": {
      "capabilities": ["dist/capabilities.d.ts"],
      "model": ["dist/model.d.ts"],
      "manifest-tools": ["dist/manifest-tools.d.ts"],
      "catalog": ["dist/catalog.d.ts"]
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/google": { "optional": true },
    "@ai-sdk/openai": { "optional": true }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@vendoai/components": "workspace:*",
    "@vendoai/core": "workspace:*",
    "@vendoai/runtime": "workspace:*",
    "@vendoai/store": "workspace:*",
    "@vendoai/telemetry": "workspace:*",
    "ai": "6.0.28",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
