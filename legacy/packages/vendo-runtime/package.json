{
  "name": "@vendoai/runtime",
  "version": "0.2.0",
  "description": "Vendo embedded agent runtime: host tools, automations, and MCP client.",
  "keywords": ["ai", "agent", "generative-ui", "automations", "mcp"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo-runtime"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/mcp": "1.0.6",
    "@ai-sdk/provider": "3.0.2",
    "@composio/core": "0.4.0",
    "@composio/vercel": "0.4.0",
    "@vendoai/core": "workspace:*",
    "ai": "6.0.28",
    "croner": "^10.0.1",
    "jsonata": "^2.2.1",
    "sucrase": "^3.35.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@vendoai/react": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
