{
  "openapi": "3.1.0",
  "info": {
    "title": "Cadence API",
    "description": "Cadence is the practice-management platform Hartwell & Associates runs its accounting firm on: client onboarding, tax-document collection, filing deadlines and client messaging. This spec is the host contract Vendo's agent acts through, as the signed-in firm user (ENG-202). All responses are enveloped as { \"data\": ... }; errors as { \"error\": { \"code\", \"message\" } } with status 400 or 404.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/dashboard": {
      "get": {
        "operationId": "getDashboard",
        "summary": "Firm-wide dashboard metrics: how many clients are missing documents, documents outstanding vs received, and the nearest filing deadline with its client.",
        "x-vendo-formats": {
          "nearestDeadline": "iso-datetime",
          "filingDeadline": "iso-datetime"
        },
        "responses": {
          "200": {
            "description": "Dashboard metrics",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/DashboardMetrics"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/clients": {
      "get": {
        "operationId": "listClients",
        "summary": "List the firm's clients with document progress, derived status and assigned staff. Filter to clients still missing documents or search by name.",
        "x-vendo-formats": {
          "filingDeadline": "iso-datetime"
        },
        "parameters": [
          {
            "name": "filter",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "missing_docs"
              ]
            },
            "description": "Set to missing_docs to return only clients with at least one outstanding document"
          },
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Case-insensitive search on business name or contact name, e.g. 'rivera'"
          }
        ],
        "responses": {
          "200": {
            "description": "Clients",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ClientSummary"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/clients/{id}": {
      "get": {
        "operationId": "getClient",
        "summary": "Fetch one client with document progress, derived status and assigned staff.",
        "x-vendo-formats": {
          "filingDeadline": "iso-datetime"
        },
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client id, e.g. cl_rivera"
          }
        ],
        "responses": {
          "200": {
            "description": "Client",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/ClientSummary"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Unknown client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/clients/{id}/documents": {
      "get": {
        "operationId": "listClientDocuments",
        "summary": "List one client's requested tax documents (their checklist) with per-document status, uploaded file and any rejection note.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client id"
          }
        ],
        "responses": {
          "200": {
            "description": "Document requests",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DocumentRequest"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Unknown client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/clients/{id}/documents/{docId}/status": {
      "post": {
        "operationId": "setDocumentStatus",
        "x-vendo-dangerous": true,
        "summary": "Advance a document through its lifecycle: 'receive' marks a missing document as uploaded (attaching a file name), 'verify' confirms an uploaded document is correct, 'reject' returns a wrong upload to missing with a reason the client sees. Verify and reject only apply to documents in status received or needs_review.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client id"
          },
          {
            "name": "docId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Document request id belonging to that client"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "action"
                ],
                "properties": {
                  "action": {
                    "type": "string",
                    "enum": [
                      "receive",
                      "verify",
                      "reject"
                    ],
                    "description": "Lifecycle transition to apply"
                  },
                  "fileName": {
                    "type": "string",
                    "description": "Uploaded file name (receive only); a plausible default is generated if omitted"
                  },
                  "reason": {
                    "type": "string",
                    "description": "Why the document was rejected (reject only); shown to the client until they re-upload"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated document",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/DocumentRequest"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Unknown action or invalid transition for the document's current status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Unknown client, or document does not belong to the client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/clients/{id}/messages": {
      "get": {
        "operationId": "listClientMessages",
        "summary": "Read one client's message thread with the firm, oldest first.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client id"
          }
        ],
        "responses": {
          "200": {
            "description": "Messages",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Message"
                      }
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Unknown client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "sendClientMessage",
        "summary": "Send a message to a client as the firm. This is what the firm uses to chase outstanding documents; the client sees it in their portal.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Client id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "body"
                ],
                "properties": {
                  "body": {
                    "type": "string",
                    "description": "Message text; must be non-empty"
                  },
                  "author": {
                    "type": "string",
                    "description": "Staff member sending the message; defaults to the signed-in user, Maya Alvarez"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The sent message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/Message"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Empty message body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Unknown client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/api/deadlines": {
      "get": {
        "operationId": "listDeadlines",
        "summary": "All clients ordered by filing deadline (soonest first), each with document progress and the kinds of documents still missing. Use this to see who is at risk of missing their deadline.",
        "x-vendo-formats": {
          "filingDeadline": "iso-datetime"
        },
        "responses": {
          "200": {
            "description": "Deadline entries, soonest first",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/DeadlineEntry"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/activity": {
      "get": {
        "operationId": "listActivity",
        "summary": "Firm-wide activity feed, newest first: uploads received, documents verified or rejected, messages sent, deadlines approaching.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "number"
            },
            "description": "Maximum number of events to return; omit for the full feed"
          }
        ],
        "responses": {
          "200": {
            "description": "Activity events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/ActivityEvent"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/demo/reset": {
      "post": {
        "operationId": "resetDemo",
        "summary": "Demo control: discard all changes and restore the seeded opening state (8 clients missing documents). Returns fresh dashboard metrics.",
        "responses": {
          "200": {
            "description": "Fresh dashboard metrics after reset",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "$ref": "#/components/schemas/DashboardMetrics"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/demo/simulate/upload": {
      "post": {
        "operationId": "simulateClientUpload",
        "summary": "Demo control: simulate a client uploading a file for a missing document. variant 'correct' lands the document in status received; variant 'wrong' (e.g. a personal bank statement instead of the business one) lands it in needs_review with an explanatory note. Also records a client-to-firm message and activity.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "clientId",
                  "docId",
                  "variant"
                ],
                "properties": {
                  "clientId": {
                    "type": "string",
                    "description": "Client doing the uploading, e.g. cl_rivera"
                  },
                  "docId": {
                    "type": "string",
                    "description": "Document request being fulfilled; must belong to the client and be in status missing"
                  },
                  "variant": {
                    "type": "string",
                    "enum": [
                      "correct",
                      "wrong"
                    ],
                    "description": "correct: plausible right file -> received. wrong: mismatched file -> needs_review with a note"
                  },
                  "fileName": {
                    "type": "string",
                    "description": "Uploaded file name; a plausible default is generated if omitted"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated document and the client's message",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "document": {
                          "$ref": "#/components/schemas/DocumentRequest"
                        },
                        "message": {
                          "$ref": "#/components/schemas/Message"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing fields, unknown variant, or the document already has an upload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Unknown client, or document does not belong to the client",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "not_found",
                  "bad_request"
                ]
              },
              "message": {
                "type": "string"
              }
            }
          }
        }
      },
      "Progress": {
        "type": "object",
        "description": "Document collection progress, rendered as e.g. '3 of 6 received'",
        "properties": {
          "received": {
            "type": "number",
            "description": "Documents no longer missing or rejected"
          },
          "total": {
            "type": "number"
          }
        }
      },
      "Staff": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "initials": {
            "type": "string"
          }
        }
      },
      "ClientSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Client id, e.g. cl_rivera"
          },
          "businessName": {
            "type": "string"
          },
          "entityType": {
            "type": "string",
            "enum": [
              "s_corp",
              "sole_prop",
              "partnership",
              "c_corp",
              "individual"
            ]
          },
          "contactName": {
            "type": "string"
          },
          "contactEmail": {
            "type": "string"
          },
          "assigneeId": {
            "type": "string"
          },
          "assignee": {
            "$ref": "#/components/schemas/Staff"
          },
          "filingDeadline": {
            "type": "string",
            "description": "ISO 8601 filing deadline"
          },
          "progress": {
            "$ref": "#/components/schemas/Progress"
          },
          "status": {
            "type": "string",
            "enum": [
              "missing_docs",
              "in_review",
              "complete"
            ],
            "description": "Derived from the client's documents"
          }
        }
      },
      "DocumentRequest": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Document request id, e.g. doc_rivera_w2"
          },
          "clientId": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "description": "What was requested, e.g. W-2, 1099-NEC, Bank statements (2025)"
          },
          "status": {
            "type": "string",
            "enum": [
              "missing",
              "received",
              "needs_review",
              "verified",
              "rejected"
            ],
            "description": "Lifecycle: missing -> received (or needs_review if the upload looks wrong) -> verified; reject returns it to missing with a note"
          },
          "note": {
            "type": "string",
            "description": "Rejection or review note shown until the client re-uploads"
          },
          "file": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "uploadedAt": {
                "type": "string",
                "description": "ISO 8601"
              }
            }
          }
        }
      },
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "clientId": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": [
              "firm",
              "client"
            ],
            "description": "firm: sent by the firm to the client; client: sent by the client"
          },
          "author": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "sentAt": {
            "type": "string",
            "description": "ISO 8601"
          }
        }
      },
      "ActivityEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "upload_received",
              "document_verified",
              "document_rejected",
              "message_sent",
              "deadline_approaching"
            ]
          },
          "clientId": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "at": {
            "type": "string",
            "description": "ISO 8601"
          }
        }
      },
      "DashboardMetrics": {
        "type": "object",
        "properties": {
          "clientsMissingDocs": {
            "type": "number",
            "description": "Clients with at least one outstanding document"
          },
          "documentsOutstanding": {
            "type": "number",
            "description": "Documents still missing or rejected across all clients"
          },
          "documentsReceived": {
            "type": "number"
          },
          "documentsTotal": {
            "type": "number"
          },
          "clientsTotal": {
            "type": "number"
          },
          "nearestDeadline": {
            "type": "string",
            "description": "ISO 8601 date of the soonest client filing deadline; the dashboard counts down to this"
          },
          "nearestDeadlineClient": {
            "type": "object",
            "description": "The client whose deadline is soonest",
            "properties": {
              "id": {
                "type": "string"
              },
              "businessName": {
                "type": "string"
              },
              "filingDeadline": {
                "type": "string"
              }
            }
          }
        }
      },
      "DeadlineEntry": {
        "allOf": [
          {
            "$ref": "#/components/schemas/ClientSummary"
          },
          {
            "type": "object",
            "properties": {
              "missingDocKinds": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Kinds of documents still owed, e.g. ['W-2', 'Receipts']; empty when the checklist is complete"
              }
            }
          }
        ]
      }
    }
  }
}