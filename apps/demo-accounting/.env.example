# Required: chat and generated UI model
# Anthropic API key used by the demo's default Claude model.
ANTHROPIC_API_KEY=

# Vendo credential forwarding
# The operator-set PUBLIC origin. Present execution forwards the signed-in
# user's Supabase session to this trusted base. Required for host tools to work.
VENDO_BASE_URL=http://localhost:3000

# Supabase Auth (real Cadence login)
# Local development needs no values here: `supabase start` (run it in this
# directory) uses the well-known local URL, anon key, and JWT secret, and the
# app defaults to them outside production. Seeded logins: maya@cadence.test
# and daniel@cadence.test, password "cadence-demo" (supabase/seed.sql).
# All three are required in production (a hosted Supabase project's values).
# Away execution mints real user JWTs with SUPABASE_JWT_SECRET — the project's
# legacy JWT secret.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=
# Login-page hint/prefill when hosted seeds differ from the local ones.
# CADENCE_DEMO_PASSWORD=

# Optional: Composio integrations
# Enables the Gmail and Google Calendar tools used by the demo agent.
# COMPOSIO_API_KEY=

# Optional: model and deployment controls
# Anthropic model id for the chat agent.
# VENDO_DEMO_MODEL=
# Optional Anthropic model id for the policy judge; unset keeps the judge disabled.
# VENDO_JUDGE_MODEL=
