# Required: chat and generated UI model
# Anthropic API key used by the demo's default Claude model.
ANTHROPIC_API_KEY=

# Vendo credential forwarding + MCP door
# The operator-set PUBLIC origin. Present execution forwards the signed-in
# user's session to this trusted base, and the door derives its OAuth
# discovery/audience URLs from it. Required for host tools to work.
VENDO_BASE_URL=http://localhost:3000

# Auth.js (real Maple login)
# Required in production; outside production a fixed local development secret
# is used so the demo boots with zero configuration. Away execution mints real
# session tokens with this same secret. Generate one with `pnpm exec auth secret`.
# AUTH_SECRET=
# Seeded demo users: yousef@maple.com (override with MAPLE_DEMO_EMAIL) and
# mia@maple.com. Both share MAPLE_DEMO_PASSWORD (default outside production:
# maple-demo). Required in production.
# MAPLE_DEMO_EMAIL=yousef@maple.com
# MAPLE_DEMO_PASSWORD=

# Optional: Composio integrations
# Enables the configured Gmail and Slack connector tools.
# COMPOSIO_API_KEY=

# Optional: voice
# Enables the microphone flow by minting OpenAI Realtime client secrets.
# OPENAI_API_KEY=
# Overrides the OpenAI Realtime model used by /api/voice.
# OPENAI_REALTIME_MODEL=
# Overrides the OpenAI Realtime output voice.
# OPENAI_REALTIME_VOICE=

# Optional: model and deployment controls
# Anthropic model id for the chat agent.
# VENDO_DEMO_MODEL=
# Set to 1 only when intentionally exposing a deployed demo to non-local requests.
# VENDO_DEMO_PUBLIC=

# Durable Vendo/OAuth store. Railway should reference Postgres.DATABASE_URL.
# DATABASE_URL=
