# Required: chat and generated UI model
# Anthropic API key used by the demo's default Claude model.
ANTHROPIC_API_KEY=

# Optional: Composio integrations
# Enables the Vendo connect flow and connected Gmail/Slack tool ingestion.
# COMPOSIO_API_KEY=
# Overrides the demo Slack channel used by the automation poster (#general by default).
# SLACK_CHANNEL_ID=
# Set to 1 to report a canned successful Slack post when the real Composio call fails.
# VENDO_STAGE_FALLBACK=

# Optional: voice
# Enables the microphone flow by minting OpenAI Realtime client secrets.
# OPENAI_API_KEY=
# Overrides the OpenAI Realtime model used by /api/vendo/voice.
# OPENAI_REALTIME_MODEL=
# Overrides the OpenAI Realtime output voice.
# OPENAI_REALTIME_VOICE=

# Optional: model and deployment controls
# Anthropic model id for the chat agent and automation step runner.
# VENDO_DEMO_MODEL=
# Set to 1 only when intentionally exposing a deployed demo to non-local requests.
# VENDO_DEMO_PUBLIC=
# Set to 1 for the persistence-drill scheduler path.
# VENDO_DRILL=
