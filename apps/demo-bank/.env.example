# Required: chat and generated UI model
# Anthropic API key used by the demo's default Claude model.
ANTHROPIC_API_KEY=

# Optional: Composio integrations
# Enables the configured Gmail and Slack connector tools.
# COMPOSIO_API_KEY=

# Optional: voice
# Enables the microphone flow by minting OpenAI Realtime client secrets.
# OPENAI_API_KEY=
# Overrides the OpenAI Realtime model used by /api/voice.
# OPENAI_REALTIME_MODEL=
# Overrides the OpenAI Realtime output voice.
# OPENAI_REALTIME_VOICE=

# Optional: model and deployment controls
# Anthropic model id for the chat agent.
# VENDO_DEMO_MODEL=
# Set to 1 only when intentionally exposing a deployed demo to non-local requests.
# VENDO_DEMO_PUBLIC=

# MCP door + Maple demo auth
# Public origin used for OAuth discovery/audience URLs behind a trusted proxy.
# VENDO_BASE_URL=http://localhost:3000
# Durable Vendo/OAuth store. Railway should reference Postgres.DATABASE_URL.
# DATABASE_URL=
# Required in production. Keep these only in the deployment environment.
# MAPLE_SESSION_SECRET=
# MAPLE_DEMO_EMAIL=yousef@maple.com
# MAPLE_DEMO_PASSWORD=
