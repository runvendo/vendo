    {
      "name": "list_transactions",
      "description": "Returns a paginated, filterable list of transactions. Supports filtering by search text, category, accountId, status, date range (from/to), amount range (min/max), sorting, and cursor-based pagination via limit and cursor.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "search": {
            "type": "string",
            "description": "Free-text search filter."
          },
          "category": {
            "type": "string",
            "description": "Filter by transaction category."
          },
          "accountId": {
            "type": "string",
            "description": "Filter by account ID."
          },
          "status": {
            "type": "string",
            "description": "Filter by transaction status."
          },
          "from": {
            "type": "string",
            "description": "Start date filter (ISO date string)."
          },
          "to": {
            "type": "string",
            "description": "End date filter (ISO date string)."
          },
          "min": {
            "type": "number",
            "description": "Minimum transaction amount filter."
          },
          "max": {
            "type": "number",
            "description": "Maximum transaction amount filter."
          },
          "sort": {
            "type": "string",
            "description": "Sort order for results."
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of results to return."
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor for fetching the next page."
          }
        }
      },
      "formats": {
        "amount": "cents"
      },
      "risk": "read",
      "binding": {
        "kind": "route",
