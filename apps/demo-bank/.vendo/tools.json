    {
      "name": "host_listTransactions",
      "description": "Search and list transactions across all accounts, with filters, sorting and cursor pagination.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "search": {
            "type": "string",
            "description": "Free-text match on merchant/descriptor"
          },
          "category": {
            "type": "string",
            "description": "Category, e.g. dining, groceries, coffee, transport, subscriptions"
          },
          "accountId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "description": "pending | authorized | posted"
          },
          "from": {
            "type": "string",
            "description": "ISO date lower bound"
          },
          "to": {
            "type": "string",
            "description": "ISO date upper bound"
          },
          "min": {
            "type": "number",
            "description": "Minimum absolute amount in cents"
          },
          "max": {
            "type": "number",
            "description": "Maximum absolute amount in cents"
          },
          "sort": {
            "type": "string",
            "description": "date_desc | date_asc | amount_desc | amount_asc"
          },
          "limit": {
            "type": "number"
          },
          "cursor": {
            "type": "string"
          }
        }
      },
      "risk": "read",
      "binding": {
        "kind": "openapi",
        "operationId": "listTransactions",
        "method": "GET",
        "path": "/api/transactions"
      }
    },
    {
      "name": "host_transferMoney",
      "description": "Send money to a person from the user's checking account. This IRREVERSIBLY MOVES MONEY: it debits checking and appends a transfer. There is no undo.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "amount": {
            "type": "integer",
            "minimum": 1,
            "description": "Amount to send in cents (positive whole number), e.g. 50000 = $500.00"
          },
          "recipient_name": {
            "type": "string",
            "description": "Who the money goes to, e.g. Alex Rivera"
          },
          "memo": {
            "type": "string",
            "description": "Optional note shown on the transfer, e.g. June rent"
          }
        },
        "required": [
          "amount",
          "recipient_name"
        ]
      },
      "risk": "destructive",
      "binding": {
        "kind": "openapi",
        "operationId": "transferMoney",
        "method": "POST",
        "path": "/api/transfers"
      }
    },
