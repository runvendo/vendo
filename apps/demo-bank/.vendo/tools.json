    {
      "name": "host_createOrder",
      "description": "Place a delivery order on the user's account. This MOVES MONEY: it charges the user's card and appends a transaction.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "body": {
            "type": "object",
            "properties": {
              "merchant": {
                "type": "string",
                "description": "Merchant name, e.g. DoorDash"
              },
              "amountCents": {
                "type": "number",
                "description": "Charge amount in cents, e.g. 3184"
              },
              "descriptor": {
                "type": "string",
                "description": "Card statement descriptor"
              },
              "items": {
                "type": "string",
                "description": "Human-readable order contents"
              },
              "hour": {
                "type": "number",
                "description": "Order hour (0-23, Pacific). Demo default is late-night."
              },
              "minute": {
                "type": "number",
                "description": "Order minute (0-59)"
              }
            }
          }
        },
        "required": [
          "body"
        ]
      },
      "risk": "write",
      "binding": {
        "kind": "openapi",
        "operationId": "createOrder",
        "method": "POST",
        "path": "/api/orders"
      }
    },
