{
  "format": "vendo/tools@1",
  "tools": [
    {
      "name": "get_account",
      "description": "Retrieves a single account by its ID. Returns the account object if found, or a 404 error if not found.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The account ID to retrieve."
          }
        },
        "required": [
          "id"
        ]
      },
      "formats": {
        "balance": "cents"
      },
      "risk": "read",
      "binding": {
        "kind": "route",
        "method": "GET",
        "path": "/api/accounts/{id}",
        "argsIn": "query"
      }
    },
    {
      "name": "get_account_transactions",
