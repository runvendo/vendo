{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["server/**/*.ts", "src/flowlet/host-components.js"]
}
