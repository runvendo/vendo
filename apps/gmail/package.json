{
  "name": "gmail-demo",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@ai-sdk/react": "3.0.30",
    "@vendoai/components": "workspace:*",
    "@vendoai/core": "workspace:*",
    "@vendoai/react": "workspace:*",
    "@vendoai/runtime": "workspace:*",
    "@vendoai/shell": "workspace:*",
    "@vendoai/stage": "workspace:*",
    "ai": "6.0.28",
    "express": "^4.21.2",
    "framer-motion": "^3.10.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^4.2.0",
    "react-redux": "^7.2.2",
    "react-router-dom": "^5.2.0",
    "react-scripts": "^5.0.1",
    "redux": "^4.0.5",
    "redux-logger": "^3.0.6",
    "reselect": "^4.0.0",
    "styled-components": "^5.2.1",
    "web-vitals": "^0.2.4",
    "zod": "^3.24.0"
  },
  "scripts": {
    "start": "PORT=3199 DISABLE_ESLINT_PLUGIN=true craco start",
    "build": "DISABLE_ESLINT_PLUGIN=true craco build",
    "dev": "concurrently -k -n server,web \"pnpm dev:server\" \"pnpm start\"",
    "dev:server": "tsx watch server/index.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.server.json --noEmit",
    "predev": "pnpm --filter @vendoai/stage build:react-shim && pnpm run build:vendo-sandbox && node scripts/copy-vendo-sandbox.mjs",
    "prebuild": "pnpm --filter @vendoai/stage build:react-shim && pnpm run build:vendo-sandbox && node scripts/copy-vendo-sandbox.mjs",
    "build:vendo-sandbox": "vite build -c vendo-sandbox/vite.config.mts"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "concurrently": "^9.1.2",
    "http-proxy-middleware": "^2.0.9",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@craco/craco": "^7.1.0",
    "@ai-sdk/provider": "3.0.2"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
