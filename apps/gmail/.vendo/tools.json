{
  "version": 1,
  "tools": [
    {
      "name": "get_profile",
      "description": "Returns the signed-in user's identity (name and email address).",
      "inputSchema": {
        "type": "object",
        "properties": {}
      },
      "annotations": {
        "mutating": false,
        "dangerous": false
      },
      "binding": {
        "type": "http",
        "method": "GET",
        "path": "/api/profile"
      }
    },
    {
      "name": "list_messages",
      "description": "Lists messages newest-first. Filter by folder (inbox, sent, trash — default inbox), unread, starred, a free-text search query, and a result limit. Use unread=true to get the user's unread emails.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "folder": {
            "type": "string",
            "enum": [
              "inbox",
              "sent",
              "trash"
            ],
            "description": "Which folder to list: inbox (default), sent, or trash."
          },
          "unread": {
            "type": "boolean",
            "description": "true → only unread messages; false → only read ones."
          },
          "starred": {
            "type": "boolean",
            "description": "true → only starred messages."
          },
          "q": {
            "type": "string",
            "description": "Case-insensitive search across sender, subject and body."
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "description": "Maximum number of messages to return."
          }
        }
      },
      "annotations": {
        "mutating": false,
        "dangerous": false
      },
      "binding": {
        "type": "http",
        "method": "GET",
        "path": "/api/messages"
      }
    },
    {
      "name": "get_message",
      "description": "Reads one message in full (headers and complete body) by id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The message id, e.g. \"m5\"."
          }
        },
        "required": [
          "id"
        ]
      },
      "annotations": {
        "mutating": false,
        "dangerous": false
      },
      "binding": {
        "type": "http",
        "method": "GET",
        "path": "/api/messages/{id}"
      }
    },
    {
      "name": "delete_message",
      "description": "Deletes a message (moves it to trash). Destructive — requires the user's approval.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The message id to delete."
          }
        },
        "required": [
          "id"
        ]
      },
      "annotations": {
        "mutating": true,
        "dangerous": true,
        "idempotent": true
      },
      "binding": {
        "type": "http",
        "method": "DELETE",
        "path": "/api/messages/{id}"
      }
    },
    {
      "name": "send_message",
      "description": "Sends an email as the signed-in user. For replies pass inReplyTo (the original message id) — recipient and Re: subject then default from the original. Sends on the user's behalf — requires approval.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "body": {
            "type": "object",
            "properties": {
              "to": {
                "type": "string",
                "description": "Recipient email address. Optional when replying."
              },
              "subject": {
                "type": "string",
                "description": "Subject line. Optional when replying (defaults to Re: original)."
              },
              "body": {
                "type": "string",
                "description": "Plain-text body of the email."
              },
              "inReplyTo": {
                "type": "string",
                "description": "Id of the message being replied to."
              }
            },
            "required": [
              "body"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "body"
        ]
      },
      "annotations": {
        "mutating": true,
        "dangerous": false
      },
      "binding": {
        "type": "http",
        "method": "POST",
        "path": "/api/messages/send"
      }
    },
    {
      "name": "mark_message_read",
      "description": "Marks a message read (read=true) or unread (read=false).",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The message id."
          },
          "body": {
            "type": "object",
            "properties": {
              "read": {
                "type": "boolean",
                "description": "true = read, false = unread."
              }
            },
            "required": [
              "read"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "body"
        ]
      },
      "annotations": {
        "mutating": true,
        "dangerous": false
      },
      "binding": {
        "type": "http",
        "method": "POST",
        "path": "/api/messages/{id}/read"
      }
    },
    {
      "name": "star_message",
      "description": "Stars (starred=true) or unstars (starred=false) a message.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "The message id."
          },
          "body": {
            "type": "object",
            "properties": {
              "starred": {
                "type": "boolean",
                "description": "true = star, false = unstar."
              }
            },
            "required": [
              "starred"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "id",
          "body"
        ]
      },
      "annotations": {
        "mutating": true,
        "dangerous": false
      },
      "binding": {
        "type": "http",
        "method": "POST",
        "path": "/api/messages/{id}/star"
      }
    }
  ],
  "events": []
}
