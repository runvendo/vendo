{
  "name": "@vendoai/guard",
  "version": "0.3.0",
  "description": "Vendo's policy core at one choke point: guard.bind, approvals, grants, audit, Vendo Auto judge, breakers, scanners.",
  "keywords": [
    "ai",
    "agent",
    "guardrails",
    "policy",
    "vendo"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/guard"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@vendoai/core": "workspace:*",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "ai": "^5.0.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^2.0.85",
    "@electric-sql/pglite": "^0.2.0",
    "@types/node": "^22.0.0",
    "ai": "^5.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
