{
  "name": "@vendoai/components",
  "version": "0.1.0",
  "description": "Brand-themeable component catalog for Vendo generated UI.",
  "keywords": ["ai", "agent", "generative-ui", "react", "components", "ui"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo-components"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./descriptors": {
      "types": "./dist/descriptors.d.ts",
      "default": "./dist/descriptors.js"
    },
    "./theme": {
      "types": "./dist/theme/brand.d.ts",
      "default": "./dist/theme/brand.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox-install.d.ts",
      "default": "./dist/sandbox-install.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:sandbox": "vite build -c vite.sandbox.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@vendoai/core": "workspace:*",
    "@openuidev/react-headless": "^0.8.2",
    "@openuidev/react-lang": "^0.2.6",
    "@openuidev/react-ui": "^0.11.9",
    "d3-sankey": "^0.12.3",
    "d3-shape": "^3.2.0",
    "lucide-react": "^0.562.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/d3-sankey": "^0.12.5",
    "@types/d3-shape": "^3.1.8",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "zod-to-json-schema": "^3.25.2"
  }
}
