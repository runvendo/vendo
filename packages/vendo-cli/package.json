{
  "name": "@vendoai/cli",
  "version": "0.2.0",
  "description": "One-command Vendo install: extracts theme, tools, and components from a host app and wires in the embedded agent.",
  "keywords": [
    "ai",
    "agent",
    "generative-ui",
    "cli",
    "devtool"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo-cli"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "vendo": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && node scripts/bundle-assets.mjs",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@clack/prompts": "1.6.0",
    "@scarf/scarf": "^1.4.0",
    "ai": "6.0.28",
    "esbuild": "^0.25.0",
    "picocolors": "^1.1.1",
    "sucrase": "^3.35.0",
    "typescript": "^5.9.0",
    "yaml": "^2.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "3.0.2",
    "@types/node": "^22.0.0",
    "@vendoai/components": "workspace:*",
    "@vendoai/core": "workspace:*",
    "@vendoai/sandbox-shims": "workspace:*",
    "@vendoai/server": "workspace:*",
    "@vendoai/telemetry": "workspace:*",
    "ajv": "^8.17.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "scarfSettings": {
    "defaultOptIn": true,
    "allowTopLevel": true
  }
}
