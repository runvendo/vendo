{
  "name": "@vendoai/vendo",
  "version": "0.3.0",
  "description": "The Vendo umbrella: default composition, public wire routes, React provider, and the vendo CLI.",
  "keywords": ["ai", "agent", "genui", "react", "vendo"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vendo": "bin/vendo.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vendoai/actions": "workspace:*",
    "@vendoai/agent": "workspace:*",
    "@vendoai/apps": "workspace:*",
    "@vendoai/automations": "workspace:*",
    "@vendoai/core": "workspace:*",
    "@vendoai/guard": "workspace:*",
    "@vendoai/mcp": "workspace:*",
    "@vendoai/store": "workspace:*",
    "@vendoai/telemetry": "workspace:*",
    "@vendoai/ui": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "peerDependencies": {
    "ai": ">=6.0.0 <7",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "ai": "6.0.28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
