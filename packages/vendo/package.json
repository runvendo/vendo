{
  "name": "@vendoai/vendo",
  "version": "0.3.0",
  "description": "The Vendo umbrella: default composition, public wire routes, React provider, and the vendo CLI.",
  "keywords": [
    "ai",
    "agent",
    "genui",
    "react",
    "vendo"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "vendo": "bin/vendo.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./extract": {
      "types": "./dist/cli/extract/index.d.ts",
      "default": "./dist/cli/extract/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build:playground": "node scripts/build-playground.mjs",
    "prebuild": "pnpm run build:playground",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm run build:playground",
    "test": "vitest run",
    "pretypecheck": "pnpm run build:playground",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest:coverage": "pnpm run build:playground",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vendoai/actions": "workspace:*",
    "@vendoai/agent": "workspace:*",
    "@vendoai/apps": "workspace:*",
    "@vendoai/automations": "workspace:*",
    "@vendoai/core": "workspace:*",
    "@vendoai/guard": "workspace:*",
    "@vendoai/mcp": "workspace:*",
    "@vendoai/store": "workspace:*",
    "@vendoai/telemetry": "workspace:*",
    "@vendoai/ui": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0 <7",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "ai": "6.0.28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
