{
  "name": "@flowlet/next",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@flowlet/components": "workspace:*",
    "@flowlet/core": "workspace:*",
    "@flowlet/react": "workspace:*",
    "@flowlet/runtime": "workspace:*",
    "@flowlet/server": "workspace:*",
    "@flowlet/shell": "workspace:*",
    "@flowlet/store": "workspace:*",
    "@scarf/scarf": "^1.4.0",
    "ai": "6.0.28",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "scarfSettings": {
    "defaultOptIn": true,
    "allowTopLevel": true
  }
}
