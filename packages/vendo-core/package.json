{
  "name": "@vendoai/core",
  "version": "0.1.0",
  "description": "Vendo core contracts: manifest schemas, the generative UI protocol, and the platform seams.",
  "keywords": ["ai", "agent", "generative-ui", "schemas", "contracts"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo-core"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/stub-agent.d.ts",
      "default": "./dist/stub-agent.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate:schemas": "tsx scripts/generate-schemas.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/provider": "3.0.2",
    "@standard-schema/spec": "^1.1.0",
    "ai": "6.0.28",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "ajv": "^8.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod-to-json-schema": "^3.24.0"
  }
}
