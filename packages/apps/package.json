{
  "name": "@vendoai/apps",
  "version": "0.4.4",
  "description": "The Vendo app artifact, build engine, sandbox seam, and runtime.",
  "keywords": [
    "ai",
    "agent",
    "apps",
    "vendo"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/apps"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./e2b": {
      "types": "./dist/e2b/index.d.ts",
      "default": "./dist/e2b/index.js"
    },
    "./adapter-conformance": {
      "types": "./dist/adapter-conformance.d.ts",
      "default": "./dist/adapter-conformance.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@vendoai/core": "workspace:*",
    "croner": "^9.0.0",
    "esbuild": "^0.25.0",
    "fflate": "^0.8.2",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "ai": ">=6.0.0 <7",
    "e2b": "^2.32.0",
    "vitest": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    },
    "e2b": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@types/node": "^22.0.0",
    "ai": "6.0.28",
    "e2b": "^2.32.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
