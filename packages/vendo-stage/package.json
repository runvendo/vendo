{
  "name": "@vendoai/stage",
  "version": "0.2.0",
  "description": "Sandboxed stage runtime and bridge for Vendo agent-generated UI.",
  "keywords": ["ai", "agent", "generative-ui", "sandbox", "iframe"],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/runvendo/vendo.git",
    "directory": "packages/vendo-stage"
  },
  "homepage": "https://vendo.run",
  "bugs": "https://github.com/runvendo/vendo/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./build": {
      "types": "./dist/build/preset.d.ts",
      "import": "./dist/build/preset.js",
      "default": "./dist/build/preset.js"
    }
  },
  "typesVersions": {
    "*": {
      "build": ["dist/build/preset.d.ts"]
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:bundle": "vite build -c tests/browser/vite.bundle.config.ts",
    "build:react-shim": "vite build -c tests/browser/vite.react-shim.config.ts",
    "build:bundle-ext": "vite build -c tests/browser/vite.bundle-ext.config.ts",
    "build:all-bundles": "pnpm run build:bundle && pnpm run build:react-shim && pnpm run build:bundle-ext",
    "test": "vitest run",
    "test:browser": "pnpm run build:real-bundle && playwright test -c tests/browser/playwright.config.ts",
    "build:real-bundle": "pnpm -w --filter @vendoai/components build:sandbox && node tests/browser/copy-real-bundle.mjs",
    "test:e2e": "playwright test -c tests/browser/playwright.config.ts gate-e2e-llm.spec.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vendoai/core": "workspace:*"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": ">=4.0.0",
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@playwright/test": "^1.48.0",
    "@vitejs/plugin-react": "^4.3.0",
    "axe-core": "^4.12.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
