{
  "name": "@vendoai/server",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.ts",
      "default": "./dist/capabilities.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "default": "./dist/model.js"
    },
    "./manifest-tools": {
      "types": "./dist/manifest-tools.d.ts",
      "default": "./dist/manifest-tools.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "default": "./dist/catalog.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/google": { "optional": true },
    "@ai-sdk/openai": { "optional": true }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.12",
    "@vendoai/components": "workspace:*",
    "@vendoai/core": "workspace:*",
    "@vendoai/runtime": "workspace:*",
    "@vendoai/shell": "workspace:*",
    "@vendoai/store": "workspace:*",
    "@vendoai/telemetry": "workspace:*",
    "ai": "6.0.28",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
