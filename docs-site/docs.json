{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Vendo",
  "description": "Embed an agent in your product that lets every customer automate their work, build their own views, and connect their tools, inside your brand and your guardrails.",
  "appearance": {
    "default": "light"
  },
  "colors": {
    "primary": "#6c3bff",
    "light": "#a78bfa",
    "dark": "#8b6bff"
  },
  "background": {
    "color": {
      "light": "#ffffff",
      "dark": "#0a0a0c"
    }
  },
  "fonts": {
    "family": "Onest"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "contextual": {
    "options": ["copy", "view", "mcp", "chatgpt", "claude", "cursor", "vscode"]
  },
  "navigation": {
    "groups": [
      {
        "group": "Start here",
        "pages": ["index", "install", "concepts/architecture", "concepts/tools-and-safety"]
      },
      {
        "group": "Bring your own agent",
        "tag": "Recommended",
        "pages": ["existing-agents/index", "existing-agents/ai-sdk", "existing-agents/mastra", "existing-agents/embeds"]
      },
      {
        "group": "Use Vendo's agent",
        "tag": "Beta",
        "pages": ["quickstart", "ui/components"]
      },
      {
        "group": "Connect your app",
        "pages": ["connect/vendo-init", "connect/api-tools", "connect/act-as-presets", "connect/dev-mode"]
      },
      {
        "group": "Make it yours",
        "pages": ["connect/theming", "connect/host-components", "connect/instructions"]
      },
      {
        "group": "Give it reach",
        "pages": ["capabilities/connected-accounts", "capabilities/mcp", "capabilities/mcp-registry", "capabilities/compound-tools", "concepts/generated-ui", "concepts/in-client-venue"]
      },
      {
        "group": "Ship it",
        "pages": ["deploy/deploying", "deploy/persistence", "deploy/vendo-cloud", "deploy/principals-and-orgs", "deploy/scheduler-and-webhooks", "deploy/telemetry", "deploy/troubleshooting"]
      },
      {
        "group": "For coding agents",
        "pages": ["agents/index", "agents/host-auth", "agents/tools", "agents/verify"]
      },
      {
        "group": "Reference",
        "pages": ["reference/handler-options", "reference/server-api", "reference/hooks", "reference/cli", "reference/dot-vendo", "reference/http-routes", "reference/environment-variables"]
      },
      {
        "group": "Changelog",
        "pages": ["changelog/overview"]
      }
    ]
  },
  "redirects": [
    {
      "source": "/quickstart-node",
      "destination": "/quickstart",
      "permanent": true
    },
    {
      "source": "/capabilities/integrations",
      "destination": "/capabilities/connected-accounts",
      "permanent": true
    },
    {
      "source": "/capabilities/voice",
      "destination": "/ui/components",
      "permanent": true
    },
    {
      "source": "/concepts/prompts",
      "destination": "/connect/instructions",
      "permanent": true
    },
    {
      "source": "/connect/tool-labels",
      "destination": "/ui/components",
      "permanent": true
    }
  ],
  "footer": {
    "socials": {
      "github": "https://github.com/runvendo/vendo"
    }
  }
}
