{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Vendo",
  "description": "Embed an agent in your product that lets every customer automate their work, build their own views, and connect their tools, inside your brand and your guardrails.",
  "appearance": {
    "default": "light"
  },
  "colors": {
    "primary": "#4338CA",
    "light": "#818CF8",
    "dark": "#4338CA"
  },
  "background": {
    "color": {
      "light": "#FAFAF8",
      "dark": "#17171A"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "contextual": {
    "options": ["copy", "view", "mcp", "chatgpt", "claude", "cursor", "vscode"]
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting started",
        "pages": ["index", "install", "quickstart", "quickstart-node"]
      },
      {
        "group": "Use with your existing agent",
        "pages": ["existing-agents/index", "existing-agents/ai-sdk", "existing-agents/mastra"]
      },
      {
        "group": "For coding agents",
        "pages": ["agents/index", "agents/host-auth", "agents/tools", "agents/verify"]
      },
      {
        "group": "Concepts",
        "pages": ["concepts/architecture", "concepts/generated-ui", "concepts/in-client-venue", "concepts/tools-and-safety", "concepts/prompts"]
      },
      {
        "group": "Connect your app",
        "pages": ["connect/vendo-init", "connect/dev-mode", "connect/api-tools", "connect/act-as-presets", "connect/host-components", "connect/theming", "connect/tool-labels", "connect/instructions"]
      },
      {
        "group": "UI",
        "pages": ["ui/components"]
      },
      {
        "group": "Capabilities",
        "pages": ["capabilities/integrations", "capabilities/connected-accounts", "capabilities/compound-tools", "capabilities/mcp", "capabilities/mcp-registry", "capabilities/voice"]
      },
      {
        "group": "Deploy and operate",
        "pages": ["deploy/persistence", "deploy/deploying", "deploy/vendo-cloud", "deploy/principals-and-orgs", "deploy/scheduler-and-webhooks", "deploy/telemetry", "deploy/troubleshooting"]
      },
      {
        "group": "Reference",
        "pages": ["reference/handler-options", "reference/server-api", "reference/hooks", "reference/cli", "reference/dot-vendo", "reference/http-routes", "reference/environment-variables"]
      },
      {
        "group": "Changelog",
        "pages": ["changelog/overview"]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/runvendo/vendo"
    }
  }
}
