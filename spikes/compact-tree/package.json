{
  "name": "@vendoai/spike-compact-tree",
  "version": "0.0.0",
  "private": true,
  "description": "SPIKE (not shipped): compact encodings of the vendo-genui/v1 tree — lossless round-trip prototypes, token-savings measurement, and live latency/validity trials. Evidence only; nothing here is registered as a wire format.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "measure:tokens": "node dist/measure-tokens.js",
    "generate:fixtures": "node dist/generate-fixtures.js",
    "measure:latency": "node dist/generate-latency.js"
  },
  "dependencies": {
    "@vendoai/core": "workspace:*",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
