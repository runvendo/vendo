  "wire": "<App name=\"Monday morning overview\">\n  <Query id=\"hostGetDashboard\" tool=\"host_getDashboard\" input={{}}/>\n  <Query id=\"hostListClients\" tool=\"host_listClients\" input={{}}/>\n  <Query id=\"hostListDeadlines\" tool=\"host_listDeadlines\" input={{}}/>\n  <Query id=\"hostListClients2\" tool=\"host_listClients\" input={{ filter: \"missing\" }}/>\n  <Stack gap={5}>\n    <Row gap={4}>\n      <CadenceMissingDocsHero missingCount={hostGetDashboard.clientsMissingDocuments} clientCount={hostListClients.data.length} badgeLabel=\"Chase now\"/>\n      <Stat label=\"Documents outstanding\" value={hostGetDashboard.documentsOutstanding}/>\n      <Stat label=\"Documents received\" value={hostGetDashboard.documentsReceived}/>\n    </Row>\n    <Row gap={4}>\n      <Stat label=\"Nearest filing deadline\" value={hostGetDashboard.nearestDeadline.dueDate} format=\"date\"/>\n      <Stat label=\"Client at risk\" value={hostGetDashboard.nearestDeadline.clientName}/>\n    </Row>\n    <Divider/>\n    <Text variant=\"heading\" text=\"Clients approaching deadlines\"/>\n    <DataTable rows={hostListDeadlines.data} sortBy=\"deadline asc\" searchable paginate={8} columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\" }, { key: \"deadline\", label: \"Filing deadline\", format: \"date\" }, { key: \"documentsReceived\", label: \"Received\" }, { key: \"documentsTotal\", label: \"Total\" }, { key: \"status\", label: \"Status\" }]} emptyState=\"No upcoming deadlines found.\"/>\n    <Divider/>\n    <Text variant=\"heading\" text=\"Clients missing documents\"/>\n    <DataTable rows={hostListClients2.data} sortBy=\"deadline asc\" searchable paginate={8} filterableBy={[\"assignedStaff\"]} columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\" }, { key: \"assignedStaff\", label: \"Assigned to\" }, { key: \"documentsReceived\", label: \"Docs received\" }, { key: \"documentsTotal\", label: \"Docs total\" }, { key: \"status\", label: \"Status\" }]} emptyState=\"No clients are missing documents — nothing to chase this week.\"/>\n    <Divider/>\n    <Disclaimer title=\"Revenue billed this month\" reason=\"This practice management tool does not have billing or invoicing data. Revenue figures can't be shown here — check your billing system for this month's totals.\"/>\n  </Stack>\n</App>",
