  "wire": "<App name=\"Monday Morning Practice Overview\">\n  <Query id=\"dashboard\" tool=\"host_getDashboard\" input={{}}/>\n  <Query id=\"deadlines\" tool=\"host_listDeadlines\" input={{}}/>\n  <Query id=\"activity\" tool=\"host_listActivity\" input={{ limit: 20 }}/>\n  <Query id=\"missingClients\" tool=\"host_listClients\" input={{ filter: \"missing\" }}/>\n  <Stack gap={6}>\n    <Row gap={2}>\n      <Text variant=\"heading\" text=\"Monday Morning Overview\"/>\n      This part of the request isn't available on this host.\n    </Row>\n    <Grid columns={3}>\n      <CadenceMissingDocsHero missingCount={dashboard.clientsMissingDocuments} clientCount={dashboard.totalClients} badgeLabel=\"Chase now\"/>\n      <Surface>\n        <Stack gap={3}>\n          <Text variant=\"caption\" text=\"Documents outstanding\"/>\n          <Stat label=\"Outstanding\" value={dashboard.documentsOutstanding} format=\"number\" tone=\"danger\"/>\n          <Divider/>\n          <Stat label=\"Received\" value={dashboard.documentsReceived} format=\"number\" tone=\"default\"/>\n          <CadenceDocProgress value={dashboard.documentsReceived} max={dashboard.documentsTotalRequested}/>\n        </Stack>\n      </Surface>\n      <Surface>\n        <Stack gap={3}>\n          <Text variant=\"caption\" text=\"Nearest filing deadline\"/>\n          <Text variant=\"heading\" text={dashboard.nearestDeadlineClientName}/>\n          <DateTime value={dashboard.nearestDeadlineDate} mode=\"date\"/>\n          <DateTime value={dashboard.nearestDeadlineDate} mode=\"relative\"/>\n          <CadenceStatusBadge text=\"Deadline approaching\" variant=\"overdue\" dot/>\n        </Stack>\n      </Surface>\n    </Grid>\n    <Disclaimer title=\"Revenue billed this month\" reason=\"No billing or invoicing tool is available on this host. Revenue figures cannot be shown.\"/>\n    <Divider/>\n    <Stack gap={2}>\n      <Text variant=\"heading\" text=\"Upcoming filing deadlines\"/>\n      <DataTable rows={deadlines.data} sortBy=\"deadline asc\" searchable paginate={10} emptyState=\"No upcoming deadlines — all clients are clear.\" columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\", format: \"string\" }, { key: \"assignedStaff\", label: \"Staff\" }, { key: \"deadline\", label: \"Filing deadline\", format: \"date\" }, { key: \"documentsReceived\", label: \"Received\" }, { key: \"documentsTotal\", label: \"Total\" }, { key: \"status\", label: \"Status\", format: \"enum\" }]}/>\n    </Stack>\n    <Divider/>\n    <Stack gap={2}>\n      <Text variant=\"heading\" text=\"Clients missing documents\"/>\n      <DataTable rows={missingClients.data} sortBy=\"deadline asc\" searchable paginate={10} filterableBy={[\"assignedStaff\", \"status\"]} emptyState=\"No documents outstanding — nothing to chase this week.\" columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\" }, { key: \"assignedStaff\", label: \"Staff\" }, { key: \"deadline\", label: \"Deadline\", format: \"date\" }, { key: \"documentsReceived\", label: \"Docs received\" }, { key: \"documentsTotal\", label: \"Docs total\" }, { key: \"status\", label: \"Status\", format: \"enum\" }]}/>\n    </Stack>\n    <Divider/>\n    <Stack gap={2}>\n      <Text variant=\"heading\" text=\"Recent activity\"/>\n      <DataTable rows={activity.data} sortBy=\"at desc\" limit={15} emptyState=\"No recent activity.\" columns={[{ key: \"at\", label: \"When\", format: \"datetime\" }, { key: \"clientName\", label: \"Client\" }, { key: \"type\", label: \"Event\", format: \"enum\" }, { key: \"description\", label: \"Detail\" }]}/>\n    </Stack>\n  </Stack>\n</App>",
