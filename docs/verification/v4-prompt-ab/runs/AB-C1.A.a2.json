  "wire": "<App name=\"Monday Morning Practice Overview\">\n  <Query id=\"dash\" tool=\"host_getDashboard\" input={{}}/>\n  <Query id=\"deadlines\" tool=\"host_listDeadlines\" input={{}}/>\n  <Query id=\"activity\" tool=\"host_listActivity\" input={{ limit: 20 }}/>\n  <Stack gap={6}>\n    <Row gap={2}>\n      <Text variant=\"heading\" text=\"Monday Morning Overview\"/>\n      This part of the request isn't available on this host.\n    </Row>\n    <Grid columns={3}>\n      <CadenceMissingDocsHero missingCount={dash.clientsMissingDocuments} clientCount={dash.totalClients} badgeLabel=\"Chase now\"/>\n      <Surface>\n        <Stack gap={3}>\n          <Text variant=\"caption\" text=\"Documents outstanding\"/>\n          <Stat label=\"Outstanding\" value={dash.documentsOutstanding} format=\"number\" tone=\"danger\"/>\n          <Divider/>\n          <Stat label=\"Received\" value={dash.documentsReceived} format=\"number\" tone=\"default\"/>\n          <CadenceDocProgress value={dash.documentsReceived} max={dash.documentsTotalRequested}/>\n        </Stack>\n      </Surface>\n      <Surface>\n        <Stack gap={3}>\n          <Text variant=\"caption\" text=\"Nearest filing deadline\"/>\n          <Text variant=\"heading\" text={dash.nearestDeadlineClientName}/>\n          <DateTime value={dash.nearestDeadlineDate} mode=\"date\"/>\n          <DateTime value={dash.nearestDeadlineDate} mode=\"relative\"/>\n        </Stack>\n      </Surface>\n    </Grid>\n    <Disclaimer title=\"Revenue not available\" reason=\"This host does not expose billing or invoicing data, so monthly revenue cannot be shown.\"/>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Upcoming filing deadlines\"/>\n        <DataTable rows={deadlines.data} sortBy=\"deadline asc\" paginate={10} searchable columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\", format: \"string\" }, { key: \"assignedStaff\", label: \"Staff\" }, { key: \"deadline\", label: \"Deadline\", format: \"date\" }, { key: \"documentsReceived\", label: \"Received\" }, { key: \"documentsTotal\", label: \"Total\" }, { key: \"status\", label: \"Status\" }]} emptyState=\"No upcoming deadlines found.\"/>\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Recent activity\"/>\n        <DataTable rows={activity.data} limit={15} columns={[{ key: \"occurredAt\", label: \"When\", format: \"datetime\" }, { key: \"clientName\", label: \"Client\" }, { key: \"type\", label: \"Event\" }, { key: \"description\", label: \"Detail\" }]} emptyState=\"No recent activity.\"/>\n      </Stack>\n    </Surface>\n  </Stack>\n</App>",
