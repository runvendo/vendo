  "wire": "<App name=\"Annual tax summary\">\n  <Query id=\"hostGetCashflowInsights\" tool=\"host_getCashflowInsights\" input={{}}/>\n  <Query id=\"hostGetSpendingInsights\" tool=\"host_getSpendingInsights\" input={{}}/>\n  <Query id=\"hostGetBudgets\" tool=\"host_getBudgets\" input={{}}/>\n  <Query id=\"hostGetRecurringInsights\" tool=\"host_getRecurringInsights\" input={{}}/>\n  <Stack gap={5}>\n    <Disclaimer title=\"Tax data isn't available on this account\" reason=\"This host has no tools for capital gains, deductible expenses, or tax liability calculations. Tax figures require a dedicated tax service or integration (such as TurboTax or a CPA platform) — they cannot be derived from your transaction history without risk of error. The spending and cashflow summaries below show what this account can see.\"/>\n    <Row gap={4}>\n      <Stat label=\"Total inflow (2026)\" value={hostGetCashflowInsights.totalInflowCents} format=\"money\" tone=\"accent\"/>\n      <Stat label=\"Total outflow (2026)\" value={hostGetCashflowInsights.totalOutflowCents} format=\"money\"/>\n      <Stat label=\"Net cashflow\" value={hostGetCashflowInsights.netCents} format=\"money\"/>\n    </Row>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Spending by category (current period)\"/>\n        This part of the request isn't available on this host.\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Category budgets vs. spend\"/>\n        <DataTable rows={hostGetBudgets.budgets} columns={[{ key: \"category\", label: \"Category\" }, { key: \"spentCents\", label: \"Spent\", format: \"money\", align: \"end\" }, { key: \"limitCents\", label: \"Budget\", format: \"money\", align: \"end\" }, { key: \"status\", label: \"Status\" }]} emptyState=\"No budget data available.\"/>\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Recurring charges detected\"/>\n        <DataTable rows={hostGetRecurringInsights.charges} columns={[{ key: \"merchant\", label: \"Merchant\" }, { key: \"amountCents\", label: \"Amount\", format: \"money\", align: \"end\" }, { key: \"frequency\", label: \"Frequency\" }, { key: \"category\", label: \"Category\" }]} emptyState=\"No recurring charges detected.\"/>\n      </Stack>\n    </Surface>\n  </Stack>\n</App>",
