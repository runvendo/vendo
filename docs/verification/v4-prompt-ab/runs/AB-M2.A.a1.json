  "wire": "<App name=\"UpcomingScheduledPayments\">\n  <Query id=\"scheduled\" tool=\"host_listScheduledPayments\" input={{}}/>\n  <Query id=\"accounts\" tool=\"host_listAccounts\" input={{}}/>\n  <Stack gap={4}>\n    <Text variant=\"heading\" text=\"Upcoming Scheduled Payments\"/>\n    <Surface>\n      <DataTable rows={scheduled.data} columns={[{ key: \"payee\", label: \"Payee\" }, { key: \"amountCents\", label: \"Amount\", format: \"money\", align: \"end\" }, { key: \"dueDate\", label: \"Due Date\", format: \"date\" }, { key: \"status\", label: \"Status\" }]} sortBy=\"dueDate asc\" emptyState=\"No upcoming scheduled payments.\" searchable/>\n    </Surface>\n    <Text variant=\"heading\" text=\"Pay Next Scheduled Payment\"/>\n    <Surface>\n      <Stack gap={3}>\n        <Grid columns={2}>\n          <Stack gap={1}>\n            <Text variant=\"caption\" text=\"Payee\"/>\n            <Text text={{ \"$path\": \"/scheduled/data/0/payee\" }}/>\n          </Stack>\n          <Stack gap={1}>\n            <Text variant=\"caption\" text=\"Amount\"/>\n            <Money cents={{ \"$path\": \"/scheduled/data/0/amountCents\" }}/>\n          </Stack>\n          <Stack gap={1}>\n            <Text variant=\"caption\" text=\"Due Date\"/>\n            <DateTime value={{ \"$path\": \"/scheduled/data/0/dueDate\" }} mode=\"date\"/>\n          </Stack>\n          <Stack gap={1}>\n            <Text variant=\"caption\" text=\"Status\"/>\n            <EnumBadge value={{ \"$path\": \"/scheduled/data/0/status\" }}/>\n          </Stack>\n        </Grid>\n        <Divider/>\n        <Stack gap={1}>\n          <Text variant=\"caption\" text=\"From Account\"/>\n          <Row gap={2}>\n            <Text text={{ \"$path\": \"/accounts/data/0/name\" }}/>\n            <Text variant=\"caption\" text=\"Balance:\"/>\n            <Money cents={{ \"$path\": \"/accounts/data/0/balanceCents\" }}/>\n          </Row>\n        </Stack>\n        <Button label=\"Pay Now\" variant=\"primary\" onClick={{ action: \"host_transferMoney\", payload: { amount: { \"$path\": \"/scheduled/data/0/amountCents\" }, recipient_name: { \"$path\": \"/scheduled/data/0/payee\" }, memo: { \"$path\": \"/scheduled/data/0/dueDate\" } } }}/>\n      </Stack>\n    </Surface>\n  </Stack>\n</App>",
