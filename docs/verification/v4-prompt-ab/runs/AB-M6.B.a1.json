  "wire": "<App name=\"Annual spending summary (tax prep aid)\">\n  <Query id=\"hostGetCashflowInsights\" tool=\"host_getCashflowInsights\" input={{}}/>\n  <Query id=\"hostGetSpendingInsights\" tool=\"host_getSpendingInsights\" input={{}}/>\n  <Query id=\"hostGetRecurringInsights\" tool=\"host_getRecurringInsights\" input={{}}/>\n  <Stack gap={5}>\n    <Disclaimer title=\"Tax data isn't available on this account\" reason=\"This host has no tools for capital gains, deductible expenses, or tax liability calculations. Tax data requires integration with a tax service (e.g. TurboTax, H&R Block) or your brokerage — none of which are connected here. What is shown below is your real spending and cashflow for 2026, which may help you or your accountant prepare a return.\"/>\n    <Surface>\n      <Stack gap={4}>\n        <Text variant=\"heading\" text=\"2026 cashflow overview\"/>\n        <Row gap={4}>\n          <Stat label=\"Total inflow\" value={hostGetCashflowInsights.totalInflowCents} format=\"money\"/>\n          <Stat label=\"Total outflow\" value={hostGetCashflowInsights.totalOutflowCents} format=\"money\"/>\n          <Stat label=\"Net cashflow\" value={hostGetCashflowInsights.netCents} format=\"money\"/>\n        </Row>\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={4}>\n        <Text variant=\"heading\" text=\"Spending by category\"/>\n        <Row gap={4}>\n          <MapleSpendingDonut slices={hostGetSpendingInsights.categories} size={200}/>\n          <DataTable rows={hostGetSpendingInsights.categories} columns={[{ key: \"category\", label: \"Category\" }, { key: \"amount\", label: \"Amount\", format: \"money\", align: \"end\" }]} emptyState=\"No spending data for this period.\"/>\n        </Row>\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={4}>\n        <Text variant=\"heading\" text=\"Recurring charges\"/>\n        <DataTable rows={hostGetRecurringInsights.charges} columns={[{ key: \"merchant\", label: \"Merchant\" }, { key: \"category\", label: \"Category\" }, { key: \"amountCents\", label: \"Amount\", format: \"money\", align: \"end\" }, { key: \"frequency\", label: \"Frequency\" }]} emptyState=\"No recurring charges detected.\"/>\n      </Stack>\n    </Surface>\n    <Callout tone=\"warning\" title=\"Consult a tax professional\">\n      Capital gains, deductible expenses, and tax owed cannot be calculated from banking data alone. Share this spending summary with your accountant or import your transactions into a tax tool for an accurate return.\n    </Callout>\n  </Stack>\n</App>",
