  "wire": "<App name=\"Quarterly billing report\">\n  <Query id=\"hostGetDashboard\" tool=\"host_getDashboard\" input={{}}/>\n  <Query id=\"hostListClients\" tool=\"host_listClients\" input={{}}/>\n  <Query id=\"hostListDeadlines\" tool=\"host_listDeadlines\" input={{}}/>\n  <Query id=\"hostListActivity\" tool=\"host_listActivity\" input={{ limit: 30 }}/>\n  <Stack gap={5}>\n    <Disclaimer title=\"Hours and invoice data aren't available\" reason=\"This practice tool tracks tax document collection, client communication, and filing deadlines — it has no tools for time tracking, hours logged, or invoice generation. The billing report below is based on what is available: client filing status and document progress, which reflects where each client stands this quarter.\"/>\n    <Row gap={4}>\n      <Stat label=\"Total clients\" value={hostGetDashboard.clientCount}/>\n      <Stat label=\"Documents outstanding\" value={hostGetDashboard.outstandingCount} tone=\"danger\"/>\n      <Stat label=\"Documents received\" value={hostGetDashboard.receivedCount} tone=\"accent\"/>\n      <Stat label=\"Clients missing documents\" value={hostGetDashboard.missingCount}/>\n    </Row>\n    <CadenceMissingDocsHero missingCount={hostGetDashboard.missingCount} clientCount={hostGetDashboard.clientCount} badgeLabel=\"Chase outstanding\"/>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Client filing status — Q3 2026\"/>\n        <DataTable rows={hostListClients.data} sortBy=\"deadline asc\" searchable filterableBy={[\"status\", \"assignedStaff.name\"]} paginate={15} columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\" }, { key: \"assignedStaff.name\", label: \"Assigned staff\" }, { key: \"status\", label: \"Status\" }, { key: \"deadline\", label: \"Filing deadline\", format: \"date\" }, { key: \"documentsReceived\", label: \"Docs received\" }, { key: \"documentsTotal\", label: \"Docs total\" }]} emptyState=\"No clients found.\"/>\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Clients at deadline risk\"/>\n        <DataTable rows={hostListDeadlines.data} sortBy=\"deadline asc\" columns={[{ key: \"name\", label: \"Client\" }, { key: \"entityType\", label: \"Entity\" }, { key: \"deadline\", label: \"Deadline\", format: \"date\" }, { key: \"documentsReceived\", label: \"Received\" }, { key: \"documentsTotal\", label: \"Total\" }, { key: \"missingKinds\", label: \"Still missing\" }]} emptyState=\"No clients at risk — all documents are in order.\"/>\n      </Stack>\n    </Surface>\n    <Surface>\n      <Stack gap={3}>\n        <Text variant=\"heading\" text=\"Recent activity\"/>\n        <DataTable rows={hostListActivity.data} columns={[{ key: \"clientName\", label: \"Client\" }, { key: \"type\", label: \"Event\" }, { key: \"description\", label: \"Detail\" }, { key: \"at\", label: \"When\", format: \"date\" }]} emptyState=\"No recent activity.\"/>\n      </Stack>\n    </Surface>\n  </Stack>\n</App>",
